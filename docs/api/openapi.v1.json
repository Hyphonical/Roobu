              "total",
              "average",
              "peak"
            ],
            "type": "object"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta",
                "description": "Pagination metadata (present for list endpoints)."
              }
            ]
          }
        },
        "required": [
          "data"
        ],
        "type": "object"
      },
