{
  "components": {
    "schemas": {
      "ActivityDayDto": {
        "description": "A single day's activity entry.",
        "properties": {
          "count": {
            "description": "Number of posts ingested on this day.",
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "date": {
            "description": "Date in ISO 8601 format (YYYY-MM-DD).",
            "type": "string"
          },
          "intensity": {
            "description": "Normalized activity level in [0.0, 1.0].",
            "format": "double",
            "type": "number"
          }
        },
        "required": [
          "date",
          "count",
          "intensity"
        ],
        "type": "object"
      },
      "ActivityDto": {
        "description": "Activity response.",
        "properties": {
          "average": {
            "format": "double",
            "type": "number"
          },
          "days": {
            "items": {
              "$ref": "#/components/schemas/ActivityDayDto"
            },
            "type": "array"
          },
          "peak": {
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "total": {
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "days",
          "total",
          "average",
          "peak"
        ],
        "type": "object"
      },
      "ActivityParams": {
        "description": "Query parameters for the `/api/activity` endpoint.",
        "properties": {
          "days": {
            "description": "Number of days to look back (default 90, max 365).",
            "example": 90,
            "format": "int64",
            "maximum": 365,
            "minimum": 1,
            "type": [
              "integer",
              "null"
            ]
          },
          "site": {
            "description": "Sites to restrict results to. Repeated param or comma-separated.",
            "example": [
              "rule34",
              "e621"
            ],
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ApiResponse_ActivityDto": {
        "description": "Standard API response envelope.\n\nAll successful responses are wrapped in this structure to provide\nconsistent pagination metadata and a uniform client interface.",
