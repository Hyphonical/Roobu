      "ApiResponse_PostDto": {
        "description": "Standard API response envelope.\n\nAll successful responses are wrapped in this structure to provide\nconsistent pagination metadata and a uniform client interface.",
        "properties": {
          "data": {
            "description": "A post with full metadata.\n\nUsed across all endpoints that return post data (search, recent,\nsimilar, single post). The `score` field is only populated for search\nand similarity results.",
            "properties": {
              "direct_image_url": {
                "description": "URL to the full-resolution image (falls back to thumbnail if unavailable).",
                "type": "string"
              },
              "height": {
                "description": "Image height in pixels (0 if unknown).",
                "format": "int32",
                "minimum": 0,
                "type": "integer"
              },
              "ingestion_date": {
                "description": "Unix timestamp of when the post was ingested.",
                "format": "int64",
                "type": "integer"
              },
              "post_id": {
                "description": "Site-local post ID.",
                "format": "int64",
                "minimum": 0,
                "type": "integer"
              },
              "post_url": {
                "description": "Canonical URL to the post page on the source site.",
                "type": "string"
              },
              "rating": {
                "description": "Content rating (e.g. `\"s\"`, `\"q\"`, `\"e\"`).",
                "type": [
                  "string",
                  "null"
                ]
              },
              "score": {
                "description": "Cosine similarity score in [0.0, 1.0]; only set for search/similar results.",
                "format": "float",
                "type": [
                  "number",
                  "null"
                ]
              },
              "site": {
                "description": "Site name this post belongs to (e.g. `\"rule34\"`, `\"e621\"`).",
                "type": "string"
              },
              "tags": {
                "description": "Space-separated tags describing the image content.",
                "type": [
                  "string",
                  "null"
                ]
              },
              "thumbnail_url": {
                "description": "URL to a small thumbnail image.",
                "type": "string"
              },
              "width": {
                "description": "Image width in pixels (0 if unknown).",
                "format": "int32",
                "minimum": 0,
                "type": "integer"
              }
            },
            "required": [
              "post_id",
              "site",
              "post_url",
              "thumbnail_url",
              "direct_image_url",
              "width",
              "height",
              "ingestion_date"
