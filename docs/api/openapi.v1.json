  "info": {
    "description": "Semantic image search API for booru sites. Supports text queries, image URL queries, and hybrid text+image searches with optional per-site filtering.",
    "license": {
      "identifier": "MIT",
      "name": "MIT"
    },
    "title": "Roobu API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/activity": {
      "get": {
        "operationId": "activity",
        "parameters": [
          {
            "description": "Days to look back (default 90, max 365)",
            "in": "query",
            "name": "days",
            "required": false,
            "schema": {
              "format": "int64",
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "Sites to filter by (repeated or comma-separated)",
            "in": "query",
            "name": "site",
            "required": false,
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_ActivityDto"
                }
              }
            },
            "description": "Activity data"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_ErrorDto"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "summary": "Get ingestion activity over time (GitHub-style contribution graph).",
        "tags": [
          "activity"
        ]
      }
    },
    "/api/ingest/status": {
      "get": {
        "operationId": "ingest_status",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_IngestStatusDto"
                }
              }
            },
            "description": "Ingest status snapshot"
          }
        },
        "summary": "Get current ingest status.",
        "tags": [
          "ingest"
        ]
      }
    },
    "/api/post/{site}/{post_id}": {
      "get": {
        "operationId": "get_post",
        "parameters": [
          {
            "description": "Site name (e.g. rule34, e621)",
            "in": "path",
            "name": "site",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Site-local post ID",
            "in": "path",
            "name": "post_id",
            "required": true,
            "schema": {
              "format": "int64",
              "minimum": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_PostDto"
                }
              }
            },
            "description": "Post found"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_ErrorDto"
                }
              }
            },
            "description": "Post not found"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_ErrorDto"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "summary": "Get a single post by site and ID.",
        "tags": [
          "posts"
        ]
      }
    },
    "/api/recent": {
      "get": {
        "operationId": "recent",
        "parameters": [
          {
            "description": "Number of results (default 20, max 100)",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "format": "int64",
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "Sites to filter by (repeated or comma-separated)",
            "in": "query",
            "name": "site",
            "required": false,
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          {
            "description": "Pagination offset",
            "in": "query",
